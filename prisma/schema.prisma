generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum Platform {
  JUMIA
  KONGA
  JIJI
  NAIRALAND
  YOUTUBE
  MANUAL
}

enum ProductCondition {
  NEW
  UK_USED
  FAIRLY_USED
  REFURBISHED
  OPEN_BOX
  UNKNOWN
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  SCRAPE_PRODUCTS
  SCRAPE_REVIEWS
  SCRAPE_PRICES
  ANALYZE_SENTIMENT
  COMPUTE_TRUST
  UPDATE_PRICES
}

// ─── Core Models ────────────────────────────────────────

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(500)
  brand       String?  @db.VarChar(200)
  category    String?  @db.VarChar(200)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(1000)
  slug        String   @unique @db.VarChar(600)
  metadata    Json     @default("{}") @db.JsonB
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listings          ProductListing[]
  aliases           ProductAlias[]
  sentimentAnalyses SentimentAnalysis[]
  trustScores       TrustScore[]        @relation("ProductTrust")
  priceHistory      PriceHistory[]

  @@index([name])
  @@index([brand])
  @@index([category])
  @@index([slug])
  @@map("products")
}

model ProductAlias {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  alias     String   @db.VarChar(500)
  source    Platform
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([alias, source])
  @@index([alias])
  @@map("product_aliases")
}

model ProductListing {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String           @map("product_id") @db.Uuid
  platform      Platform
  externalId    String           @map("external_id") @db.VarChar(500)
  title         String           @db.VarChar(1000)
  price         Decimal          @db.Decimal(12, 2)
  currency      String           @default("NGN") @db.VarChar(3)
  condition     ProductCondition @default(UNKNOWN)
  url           String           @db.VarChar(2000)
  imageUrl      String?          @map("image_url") @db.VarChar(2000)
  vendorId      String?          @map("vendor_id") @db.Uuid
  inStock       Boolean          @default(true) @map("in_stock")
  lastScrapedAt DateTime         @default(now()) @map("last_scraped_at") @db.Timestamptz(6)
  metadata      Json             @default("{}") @db.JsonB
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor?  @relation(fields: [vendorId], references: [id])
  reviews Review[]

  @@unique([platform, externalId])
  @@index([productId])
  @@index([platform])
  @@index([price])
  @@index([condition])
  @@map("product_listings")
}

model Vendor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platform     Platform
  externalId   String   @map("external_id") @db.VarChar(500)
  name         String   @db.VarChar(500)
  profileUrl   String?  @map("profile_url") @db.VarChar(2000)
  rating       Decimal? @db.Decimal(3, 2)
  totalSales   Int      @default(0) @map("total_sales")
  joinDate     DateTime? @map("join_date") @db.Timestamptz(6)
  isVerified   Boolean  @default(false) @map("is_verified")
  metadata     Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listings    ProductListing[]
  trustScores TrustScore[]     @relation("VendorTrust")

  @@unique([platform, externalId])
  @@index([name])
  @@map("vendors")
}

model Review {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId   String   @map("listing_id") @db.Uuid
  platform    Platform
  externalId  String   @map("external_id") @db.VarChar(500)
  author      String?  @db.VarChar(200)
  rating      Int?
  title       String?  @db.VarChar(1000)
  content     String   @db.Text
  helpfulCount Int     @default(0) @map("helpful_count")
  postedAt    DateTime? @map("posted_at") @db.Timestamptz(6)
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  listing           ProductListing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sentimentAnalysis SentimentAnalysis?

  @@unique([platform, externalId])
  @@index([listingId])
  @@map("reviews")
}

model PriceHistory {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String           @map("product_id") @db.Uuid
  platform  Platform
  price     Decimal          @db.Decimal(12, 2)
  currency  String           @default("NGN") @db.VarChar(3)
  condition ProductCondition @default(UNKNOWN)
  recordedAt DateTime        @default(now()) @map("recorded_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, recordedAt])
  @@index([platform])
  @@map("price_history")
}

// ─── Intelligence Models ────────────────────────────────

model SentimentAnalysis {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  reviewId        String?  @unique @map("review_id") @db.Uuid
  platform        Platform
  sentimentScore  Decimal  @map("sentiment_score") @db.Decimal(4, 3)
  confidence      Decimal  @db.Decimal(4, 3)
  keyComplaints   String[] @map("key_complaints")
  keyPraises      String[] @map("key_praises")
  scamSignals     String[] @map("scam_signals")
  rawOutput       Json     @default("{}") @map("raw_output") @db.JsonB
  analyzedAt      DateTime @default(now()) @map("analyzed_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  review  Review? @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sentimentScore])
  @@map("sentiment_analyses")
}

model TrustScore {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String?  @map("product_id") @db.Uuid
  vendorId    String?  @map("vendor_id") @db.Uuid
  score       Int      @db.SmallInt
  factors     Json     @default("{}") @db.JsonB
  scamFlags   String[] @map("scam_flags")
  computedAt  DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  product Product? @relation("ProductTrust", fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor?  @relation("VendorTrust", fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([vendorId])
  @@index([score])
  @@map("trust_scores")
}

// ─── Operations Models ──────────────────────────────────

model ScrapingJob {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        JobType
  platform    Platform
  status      JobStatus @default(PENDING)
  payload     Json      @default("{}") @db.JsonB
  result      Json?     @db.JsonB
  error       String?   @db.Text
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@index([type, platform])
  @@map("scraping_jobs")
}

model SearchAnalytics {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  query        String   @db.VarChar(500)
  normalizedQuery String @map("normalized_query") @db.VarChar(500)
  resultsCount Int      @default(0) @map("results_count")
  responseTimeMs Int?   @map("response_time_ms")
  cacheHit     Boolean  @default(false) @map("cache_hit")
  ipAddress    String?  @map("ip_address") @db.Inet
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([normalizedQuery])
  @@index([createdAt])
  @@map("search_analytics")
}

model ApiKey {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(64)
  name        String   @db.VarChar(200)
  isActive    Boolean  @default(true) @map("is_active")
  rateLimit   Int      @default(100) @map("rate_limit")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([key])
  @@map("api_keys")
}
