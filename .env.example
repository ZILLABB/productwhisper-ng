# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/productwhisper_ng
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
PORT=8000
LOG_LEVEL=info
API_PREFIX=/api/v1

# API Keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
MASTER_API_KEY=your_master_api_key_here

# Sentiment Service
SENTIMENT_API_URL=http://localhost:5001

# YouTube Data API (optional — get from console.cloud.google.com)
YOUTUBE_API_KEY=

# Scraping
SCRAPE_INTERVAL_MINUTES=60
MAX_CONCURRENT_SCRAPES=3
SCRAPE_DELAY_MS=2000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Cache TTL (seconds)
CACHE_TTL_SEARCH=300
CACHE_TTL_PRODUCT=1800
CACHE_TTL_PRICE=600
CACHE_TTL_SENTIMENT=3600
